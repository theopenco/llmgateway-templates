{
  "name": "@llmgateway/server",
  "version": "0.0.0",
  "description": "Server-side SDK for LLM Gateway embeddable AI — mint end-user sessions and manage wallets with your secret key (like the Stripe Node SDK).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint src/"
  },
  "keywords": [
    "llm",
    "ai",
    "llmgateway",
    "wallet",
    "credits",
    "sdk"
  ],
  "author": "LLM Gateway",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theopenco/llmgateway-templates.git",
    "directory": "packages/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.10.10",
    "eslint": "^9.17.0",
    "semantic-release": "^25.0.2",
    "semantic-release-monorepo": "^8.0.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
