{
  "name": "@llmgateway/elements",
  "version": "0.0.0",
  "description": "React components for LLM Gateway embeddable AI — drop-in <BuyCredits>, <CreditBalance>, and hooks, like Stripe Elements.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint src/"
  },
  "keywords": [
    "llm",
    "ai",
    "llmgateway",
    "react",
    "stripe",
    "elements",
    "credits"
  ],
  "author": "LLM Gateway",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theopenco/llmgateway-templates.git",
    "directory": "packages/elements"
  },
  "dependencies": {
    "@llmgateway/client": "workspace:*",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.17.0",
    "react": "^19.0.0",
    "semantic-release": "^25.0.2",
    "semantic-release-monorepo": "^8.0.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
