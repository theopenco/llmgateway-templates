# Your LLM Gateway platform SECRET key (sk_…). Server-only — never expose to the browser.
# Create a project with end-user sessions enabled and a platform_secret API key.
LLMGATEWAY_SECRET_KEY=sk_your_secret_key

# LLM Gateway's Stripe publishable key, used by <BuyCredits> to load Stripe.js in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: override the hosted API/gateway URLs for local development.
# LLMGATEWAY_API_URL=http://localhost:4002
# NEXT_PUBLIC_LLMGATEWAY_API_URL=http://localhost:4002
# NEXT_PUBLIC_LLMGATEWAY_GATEWAY_URL=http://localhost:4001
